# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=biat_cv_platform

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# App
PORT=3000

# Mail — leave blank to use Ethereal test account in dev
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="BIAT CV Platform <no-reply@biat.com.tn>"

# Service URLs
PYTHON_SERVICE_URL=http://localhost:8002
LOCAL_LLM_URL=http://localhost:8001/v1/chat/completions
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
LOCAL_LLM_MODEL=phi-3
```

