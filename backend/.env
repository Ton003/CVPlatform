# ── Database ──────────────────────────────────────────────────────────────────
# NOTE: DB_HOST must be "postgres" (the Docker service name) when running in Docker.
# docker-compose.yml overrides this anyway, but keeping it consistent avoids confusion.
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=123123
DB_DATABASE=biat_cv_platform

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_secret
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="BIAT CV Platform <no-reply@biat.com.tn>"

# ── Services ──────────────────────────────────────────────────────────────────
# Use Docker service names for inter-container communication
PYTHON_SERVICE_URL=http://python-service:8002
LOCAL_LLM_URL=http://localhost:8001/v1/chat/completions

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
LOCAL_LLM_MODEL=phi-3